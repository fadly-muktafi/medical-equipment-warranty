<?xml version="1.0" encoding="UTF-8"?>

<odoo noupdate="1">

    <record id="sequence_medical_warranty" model="ir.sequence">
        <field name="name">Medical Warranty</field>
        <field name="code">medical.warranty</field>
        <field name="prefix">WRT/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="sequence_medical_warranty_claim" model="ir.sequence">
        <field name="name">Medical Warranty Claim</field>
        <field name="code">medical.warranty.claim</field>
        <field name="prefix">CLM/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>