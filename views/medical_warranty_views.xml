<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <!-- LIST VIEW -->
    <record id="view_medical_warranty_list" model="ir.ui.view">
        <field name="name">medical.warranty.list</field>
        <field name="model">medical.warranty</field>
        <field name="arch" type="xml">
            <list string="Garansi Alat Kesehatan"
                  decoration-success="state == 'active'"
                  decoration-warning="state == 'expiring'"
                  decoration-danger="state == 'expired'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="product_id"/>
                <field name="partner_id"/>
                <field name="lot_id" optional="hide"/>
                <field name="date_start" optional="hide"/>
                <field name="date_end"/>
                <field name="days_remaining" optional="show"/>
                <field name="claim_count" optional="hide" string="Klaim"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'expiring'"
                       decoration-danger="state == 'expired'"
                       decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_medical_warranty_form" model="ir.ui.view">
        <field name="name">medical.warranty.form</field>
        <field name="model">medical.warranty</field>
        <field name="arch" type="xml">
            <form string="Garansi Alat Kesehatan">
                <header>
                    <button name="action_active" type="object" string="Aktifkan"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_print_warranty_card" type="object"
                            string="Cetak Kartu Garansi" class="btn-primary"
                            invisible="state == 'draft'" icon="fa-print"/>
                    <button name="action_cancel" type="object" string="Batalkan"
                            invisible="state in ('cancelled', 'expired')"
                            confirm="Yakin ingin membatalkan garansi ini?"/>
                    <button name="action_reset_to_draft" type="object"
                            string="Set ke Draft" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,expiring,expired"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_claims" type="object"
                                class="oe_stat_button" icon="fa-wrench">
                            <field name="claim_count" widget="statinfo" string="Klaim"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name" string="Nomor Garansi"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <field name="product_requires_serial" invisible="1"/>

                    <group>
                        <group string="Detail Produk">
                            <field name="product_id"
                                   readonly="state not in ('draft',)"/>
                            <field name="lot_id"
                                   required="product_requires_serial"
                                   domain="[('product_id', '=', product_id)]"
                                   options="{'no_create': True}"/>
                            <field name="warranty_type"/>
                        </group>
                        <group string="Pelanggan &amp; Sumber">
                            <field name="partner_id"/>
                            <field name="sale_order_id" readonly="1"/>
                            <field name="sale_order_line_id" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <group>
                        <group string="Periode Garansi">
                            <field name="date_start"/>
                            <field name="duration_months"/>
                            <field name="date_end"/>
                            <field name="days_remaining"/>
                        </group>
                        <group string="Notifikasi Terkirim">
                            <field name="notify_30_sent" readonly="1"/>
                            <field name="notify_7_sent" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Catatan">
                            <field name="notes" placeholder="Catatan tambahan mengenai garansi ini..."/>
                        </page>
                        <page string="Klaim Garansi">
                            <field name="claim_ids">
                                <list editable="bottom">
                                    <field name="name" readonly="1"/>
                                    <field name="claim_date"/>
                                    <field name="description"/>
                                    <field name="state" widget="badge"
                                           decoration-info="state == 'new'"
                                           decoration-warning="state == 'progress'"
                                           decoration-success="state == 'resolved'"
                                           decoration-danger="state == 'rejected'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="view_medical_warranty_kanban" model="ir.ui.view">
        <field name="name">medical.warranty.kanban</field>
        <field name="model">medical.warranty</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="product_id"/>
                <field name="partner_id"/>
                <field name="date_end"/>
                <field name="days_remaining"/>
                <field name="state"/>
                <field name="claim_count"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <strong><field name="name"/></strong>
                            </div>
                            <div><field name="product_id"/></div>
                            <div class="text-muted"><field name="partner_id"/></div>
                            <div class="mt-1">
                                Berakhir: <field name="date_end"/>
                            </div>
                            <div t-if="record.claim_count.raw_value &gt; 0" class="mt-1">
                                <span class="badge text-bg-warning">
                                    <field name="claim_count"/> klaim
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_medical_warranty_search" model="ir.ui.view">
        <field name="name">medical.warranty.search</field>
        <field name="model">medical.warranty</field>
        <field name="arch" type="xml">
            <search string="Cari Garansi">
                <field name="name"/>
                <field name="product_id"/>
                <field name="partner_id"/>
                <field name="lot_id"/>
                <field name="sale_order_id"/>
                <filter string="Aktif" name="filter_active" domain="[('state', '=', 'active')]"/>
                <filter string="Akan Berakhir" name="filter_expiring" domain="[('state', '=', 'expiring')]"/>
                <filter string="Berakhir" name="filter_expired" domain="[('state', '=', 'expired')]"/>
                <filter string="Dibatalkan" name="filter_cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Punya Klaim" name="filter_has_claim" domain="[('claim_count', '&gt;', 0)]"/>
                <group expand="0" string="Kelompokkan">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Produk" name="group_product" context="{'group_by': 'product_id'}"/>
                    <filter string="Pelanggan" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Jenis Garansi" name="group_type" context="{'group_by': 'warranty_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- WINDOW ACTION -->
    <record id="action_medical_warranty" model="ir.actions.act_window">
        <field name="name">Garansi Alat Kesehatan</field>
        <field name="res_model">medical.warranty</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Belum ada garansi yang terdaftar
            </p>
            <p>
                Garansi akan otomatis dibuat saat Sales Order dengan produk
                alat kesehatan dikonfirmasi, atau buat secara manual di sini.
            </p>
        </field>
    </record>

</odoo>