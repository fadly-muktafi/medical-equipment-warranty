<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="view_order_form_medical_warranty" model="ir.ui.view">
        <field name="name">sale.order.form.medical.warranty.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="has_medical_product" invisible="1"/>
                <button name="action_view_warranty" type="object"
                        class="oe_stat_button" icon="fa-shield"
                        invisible="warranty_count == 0">
                    <field name="warranty_count" widget="statinfo" string="Garansi"/>
                </button>
            </xpath>

            <xpath expr="//button[@name='action_confirm']" position="after">
                <button name="action_generate_warranty" type="object"
                        string="Buat Garansi" class="btn-secondary"
                        invisible="state != 'sale' or not has_medical_product"/>
            </xpath>

        </field>
    </record>

</odoo>