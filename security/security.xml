<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record id="module_category_warranty" model="ir.module.category">
        <field name="name">Garansi Medis</field>
        <field name="sequence">25</field>
    </record>

    <record id="group_warranty_user" model="res.groups">
        <field name="name">Petugas Garansi</field>
        <field name="category_id" ref="module_category_warranty"/>
        <field name="implied_ids" eval="[(
            4, ref('base.group_user')
            )]"/>
        <field name="comment">Create, Read, Update</field>
    </record>

    <record id="group_warranty_manager" model="res.groups">
        <field name="name">Manajer Garansi</field>
        <field name="category_id" ref="module_category_warranty"/>
        <field name="implied_ids" eval="[(
            4, ref('group_warranty_user')
            )]"/>
        <field name="comment">Create, Read, Update, Delete</field>
    </record>

</odoo>